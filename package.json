{
  "name": "aws-bedrock-secret-scanner",
  "version": "1.0.0",
  "type": "module",
  "description": "AWS Bedrock Secret Scanner - Detect exposed AWS credentials and API keys on GitHub",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "scan:search": "node dist/index.js search",
    "scan:user": "node dist/index.js scan-user",
    "scan:org": "node dist/index.js scan-org",
    "scan:repo": "node dist/index.js scan-repo",
    "scan:local": "node dist/index.js scan-local",
    "clean": "rm -rf dist"
  },
  "keywords": ["aws", "bedrock", "security", "credentials", "scanner", "github", "typescript"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@aws-sdk/client-bedrock": "^3.500.0",
    "dotenv": "^16.3.1",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "punycode": "^2.3.1"
  }
}