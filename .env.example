# AWS Bedrock Secret Scanner Configuration
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (required for higher rate limits and org scanning)
# Generate at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:org
GITHUB_TOKEN=ghp_your_personal_access_token_here

# AWS Region (optional, defaults to us-east-1)
AWS_REGION=us-east-1

# Minimum severity level to report (optional)
# Levels: critical, high, medium
SCAN_SEVERITY_LEVEL=medium
